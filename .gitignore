# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Single source of truth — all ignore rules live here, no sub-folder .gitignore files.

# ── Build outputs / generated runtime artefacts ──────────────────────────────
# Path-agnostic so the reshape (src/frontend/ → ui/client/) doesn't leave stale rules.
**/.next/
**/.next-e2e/
**/dist/
**/build/
**/LogFiles/
**/coverage/
*.tsbuildinfo

# ── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
/.cache

# ── Runtime uploads / local dev data ─────────────────────────────────────────
# Folders auto-created on demand (upload.ts mkdirSync / CI mkdir -p / compose
# volume mount). No .gitkeep needed — git doesn't track empty dirs and nothing
# here needs to survive a fresh clone.
/uploads/
/ui/client/public/images
/ui/client/public/temp
/ui/client/public/uploads

# MongoDB WiredTiger storage + bundle exports
/data/**
/mongo_data

# Generated first-boot admin credentials (see services/features/Auth/initialPassword.ts)
/var/

# ── Env / secrets ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
IP.ts

# Local-only secrets / ops notes — infra IPs, cert fingerprints, passwords
/secrets.md
/secrets/

# ── TLS certs / keys (dev + prod) ────────────────────────────────────────────
/infra/certificates/
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx

# ── Editor / OS / tool cruft ─────────────────────────────────────────────────
/.idea/*
!/.idea/rcb-settings.xml
.DS_Store
Thumbs.db
desktop.ini
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local Claude state — keep launch.json (shared), ignore per-user settings
.claude/settings.local.json

# ── Legacy design reference assets (root /public/, not ui/client/public/) ────
/public/**
