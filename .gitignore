# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

#frontend
/src/frontend/.next

/src/frontend/public/images
/src/frontend/public/temp
/uploads/images/*
!/uploads/images/.gitkeep
/uploads/design-v2/*
!/uploads/design-v2/.gitkeep

/.cache

# dependencies
/node_modules
/.pnp
.pnp.js

#IDE
/.idea/*
!.idea/rcb-settings.xml

# testing
/coverage

# production
/build

# misc
.DS_Store
src/frontend/.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

IP.ts

# local-only secrets / ops notes — infra IPs, cert fingerprints, passwords
/secrets.md
/secrets/

# local dev data — MongoDB WiredTiger storage, bundle exports, log files
/data
/mongo_data
/src/frontend/public/LogFiles

# generated first-boot admin credentials (see src/Server/initialPassword.ts)
/var/

# env / secrets
.env
.env.*
!.env.example
src/frontend/.env

# TLS certs / keys — localhost dev or otherwise, never commit private keys
certificates/*
!certificates/.gitkeep
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx

# TS incremental build caches
*.tsbuildinfo

# OS cruft
Thumbs.db
desktop.ini

# local Claude state — keep launch.json (shared), ignore per-user settings
.claude/settings.local.json
/public/Gatis Priede CV.md

# design reference assets — HTML mockups, screenshots, uploaded images (large binaries)
public/design-v2/assets/
public/design-v2/skyclimber.bundle.json
public/design-v5/*.html
public/design-v5/responsive-test.html
public/design-v5/screenshots/
public/design-v5/uploads/
public/design-v6/*.html
public/design-v6/responsive-test.html
public/design-v6/screenshots/
public/design-v6/uploads/
src/frontend/public/design-v2/
