# Copy this file to `.env.local` (or `src/frontend/.env`) and fill the values.
# `.env.local` and `.env` are gitignored; `.env.example` is tracked.

# ---------- NextAuth ----------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Base URL where NextAuth receives callbacks. Local dev: http://localhost
# Prod: https://funisimo.pro
NEXTAUTH_URL=http://localhost

# Optional Google OAuth — leave empty to disable the provider entirely.
# Redirect URI to register in Google Cloud Console:
#   https://<your-host>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------- MongoDB ----------
# Full connection string. Local dev: mongodb://localhost:27017
# On-droplet with auth: mongodb://cms:<password>@localhost:27017/DB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=MAIN-DB

# Legacy Atlas fallback — only used if MONGODB_URI is blank.
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_CLUSTER_URL=

# ---------- Admin seed ----------
# Email of the admin user created on first successful Mongo connect.
ADMIN_EMAIL=admin@admin.com
# Plain-text seed password — hashed on first boot, then cleared from memory.
# Rotate from the admin UI after first login.
ADMIN_DEFAULT_PASSWORD=
# Alternative: supply a pre-computed bcrypt hash instead of the plain password.
# Takes precedence over ADMIN_DEFAULT_PASSWORD when set.
ADMIN_PASSWORD_HASH=

# bcrypt rounds. Higher = slower hashing. 10 is fine for dev; 12 for prod.
BCRYPT_ROUNDS=10

# ---------- Build / runtime ----------
# Port the Next `/api/graphql` or standalone-graphql server answers on.
# Used by getStaticProps + next-sitemap during `npm run build`.
BUILD_PORT=80
# Override the GraphQL endpoint getStaticProps talks to. Useful when
# building against an SSH-tunneled prod Mongo.
GRAPHQL_ENDPOINT=
# Optional CMS-scoped API key (not used by any core feature yet; reserved).
CMS_API_KEY=
