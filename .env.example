# Copy this file to `.env.local` (or `src/frontend/.env`) and fill the values.
# `.env.local` and `.env` are gitignored; `.env.example` is tracked.

# ---------- NextAuth ----------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Base URL where NextAuth receives callbacks. Local dev: http://localhost
# Prod: https://funisimo.pro
NEXTAUTH_URL=http://localhost

# Optional Google OAuth — leave empty to disable the provider entirely.
# Redirect URI to register in Google Cloud Console:
#   https://<your-host>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Customer-side Google OAuth (W6c) — separate client/secret from the
# admin Google app so the consent screen + branding can differ.
# AUTH_CUSTOMER_GOOGLE_ID=
# AUTH_CUSTOMER_GOOGLE_SECRET=

# Customer-side Facebook OAuth (W6c, opt-in). Off by default — only
# enable for site categories where Facebook is the dominant identity
# (events, communities). Treat the client id / secret as operator
# action — register the app in Facebook for Developers, then drop the
# real values in here.
# FACEBOOK_OAUTH_ENABLED=false
# AUTH_FACEBOOK_ID=placeholder
# AUTH_FACEBOOK_SECRET=placeholder

# Customer-side Apple OAuth (W6c, opt-in). Required equal-prominence
# on iOS if any other social login is offered (App Store guideline).
# Operator action — generate the Services ID + key in the Apple
# Developer portal, then drop the values here.
# APPLE_OAUTH_ENABLED=false
# AUTH_APPLE_ID=placeholder
# AUTH_APPLE_SECRET=placeholder

# ---------- MongoDB ----------
# Full connection string. Local dev: mongodb://localhost:27017
# On-droplet with auth: mongodb://cms:<password>@localhost:27017/DB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=MAIN-DB

# Legacy Atlas fallback — only used if MONGODB_URI is blank.
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_CLUSTER_URL=

# ---------- Admin seed ----------
# Email of the admin user created on first successful Mongo connect.
ADMIN_EMAIL=admin@admin.com
# Plain-text seed password — hashed on first boot, then cleared from memory.
# Rotate from the admin UI after first login.
ADMIN_DEFAULT_PASSWORD=
# Alternative: supply a pre-computed bcrypt hash instead of the plain password.
# Takes precedence over ADMIN_DEFAULT_PASSWORD when set.
ADMIN_PASSWORD_HASH=

# bcrypt rounds. Higher = slower hashing. 10 is fine for dev; 12 for prod.
BCRYPT_ROUNDS=10

# ---------- Build / runtime ----------
# Port the Next `/api/graphql` or standalone-graphql server answers on.
# Used by getStaticProps + next-sitemap during `npm run build`.
BUILD_PORT=80
# Override the GraphQL endpoint getStaticProps talks to. Useful when
# building against an SSH-tunneled prod Mongo.
GRAPHQL_ENDPOINT=
# Optional CMS-scoped API key (not used by any core feature yet; reserved).
CMS_API_KEY=

# ---------- Pricing / VAT / FX (W8g) ----------
# Stripe Tax — leave blank to fall back to the internal VAT regime
# calculator (`VatRegimeService`). When both are set + STRIPE_TAX_ENABLED is
# true, checkout defers tax calc to Stripe. Test keys start with `sk_test_`
# / `pk_test_`; live keys with `sk_live_` / `pk_live_`. Never commit real
# keys to git — drop them in `.env` post-merge.
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_TAX_ENABLED=false

# Seller country (uppercase ISO-3166 alpha-2). Used by the VAT regime
# resolver as the default seller tax-residence when an explicit value isn't
# passed. Default LV for Latvia operators.
SITE_SELLER_COUNTRY=LV

# Disable outbound calls during build / CI. Set to `1` and the FX +
# VIES + Stripe Tax services short-circuit to their fallback modes —
# lint, tests, and `next build` stay offline-safe.
PRICING_DISABLE_FX_FETCH=
PRICING_DISABLE_VIES_FETCH=
PRICING_DISABLE_STRIPE_FETCH=

# ---------- Backup + disaster recovery (W8e) ----------
# Restic + Backblaze B2 — daily full + 6-hourly incremental snapshots,
# weekly automated restore drill, RPO 6h / RTO 1h. Operator runbook lives
# at `docs/runbooks/backup-and-restore.md`.
#
# Flip BACKUP_ENABLED=true ONLY after the four B2_* vars below + the
# RESTIC password are set. While disabled, the BackupService methods
# short-circuit to `{ok: false, reason: 'backup-disabled'}` — the admin
# pane still renders, surfacing a banner pointing at the runbook.
BACKUP_ENABLED=false

# Backblaze B2 application-key credentials. Create the bucket FIRST, then
# generate a key scoped to that bucket with `listFiles` + `readFiles` +
# `writeFiles` (NOT `deleteFiles` — restic prune handles deletion via
# the API; an append-only key blocks a compromised droplet from wiping
# history).
B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
# Region matches the B2 bucket region. `us-west-002` is the default for
# new B2 buckets; check the bucket detail page if uncertain.
B2_REGION=us-west-002

# Restic repository passphrase. Generate with `openssl rand -base64 32`
# and store it in a password manager — losing this key means losing the
# backup history (restic can't decrypt without it). NEVER commit.
BACKUP_RESTIC_PASSWORD=

# Cron schedules. Minute + hour fields are honoured; the rest of the
# expression is accepted but ignored by the in-process scheduler. For
# more elaborate schedules run restic via systemd timers instead.
BACKUP_SCHEDULE_DAILY=0 3 * * *
BACKUP_SCHEDULE_HOURLY=0 */6 * * *

# Retention policy (snapshots kept). Restic forget --keep-* flags.
BACKUP_RETENTION_DAILY=14
BACKUP_RETENTION_HOURLY=28
