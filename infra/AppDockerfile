FROM node:20-alpine

# Use production node environment by default.
ENV NODE_ENV production

RUN apk add python3 py3-pip make g++ curl
#
#RUN echo 'http://dl-cdn.alpinelinux.org/alpine/v3.6/main' >> /etc/apk/repositories
#RUN echo 'http://dl-cdn.alpinelinux.org/alpine/v3.6/community' >> /etc/apk/repositories
#RUN apk update
#RUN apk add mongodb=3.4.4-r0

RUN npm i -g sass

WORKDIR /app
# Yarn cache ensurance

# Location for runtime-generated secrets (e.g. first-boot admin password).
# Permissions are tightened at write-time in initialPassword.ts; the dir is
# created here so the node user can write without elevating.
RUN mkdir -p /app/var && chmod 700 /app/var

# Copy the rest of the source files into the image.
COPY ./yarn.lock ./yarn.lock
COPY ./package.json ./package.json
COPY ./next-i18next.config.js ./next-i18next.config.js
COPY ./next-sitemap.config.cjs ./next-sitemap.config.cjs
COPY ./nodemon.json ./nodemon.json
COPY ./vitest.config.ts ./vitest.config.ts
COPY ./vitest.setup.ts ./vitest.setup.ts
COPY ./tools ./tools
# `infra/certificates/` is gitignored (local mkcert dev TLS for
# `npm run ssl` via services/sslServer.ts). Production terminates
# TLS at Caddy (Let's Encrypt), so the certs aren't needed in the
# image — and the directory is missing on CI/droplet, which used
# to break the build.
COPY ./ui ./ui
COPY ./services ./services
COPY ./shared ./shared

RUN --mount=type=cache,target=/root/.yarn YARN_CACHE_FOLDER=/root/.yarn yarn --frozen-lockfile
# Build runs at container start (not here) so MongoDB/GraphQL are available for getStaticProps