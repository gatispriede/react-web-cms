# syntax=docker/dockerfile:1
#
# Multi-stage build (Wave 1 Terraform/Kamal migration).
#
# Stage 1 (builder) installs deps and runs `next build` against an
# ephemeral mongo + standalone-graphql pair (`tools/docker-prebuild.js`)
# so the resulting image carries a prebuilt `.next/`. Cold-deploy used
# to run `next build` at container start which took 6-8 min on a 1-vCPU
# droplet; the GHCR-pushed prebuilt image lets the runtime stage skip
# straight to `next start` (~30 s).
#
# Stage 2 (runtime) is the slim production image. It still copies the
# full sources (admin upload paths read from `ui/client/public/`,
# runtime SSR walks `services/`) plus the prebuilt `.next/` and
# `node_modules`. CMD is `npm run start` — no rebuild, just `next
# start` against the prebuilt artefacts.
#
# Backwards compatibility: the legacy bash deploy on funisimo /
# skyclimber currently runs `npm run start-docker` (build → start) via
# `infra/compose.yaml`. That path keeps working because `start-docker`
# rebuilds at container start using the same mongo / graphql containers
# in the compose file — slower, but unchanged in shape. Once Kamal
# cutover ships, the legacy compose service moves to the prebuilt
# image and the start-docker fallback is retired.

# ---------------------------------------------------------------- builder
#
# bookworm-slim (glibc) — `mongodb-memory-server` downloads a glibc-
# linked `mongod` binary at boot for the prebuild step; Alpine's musl
# rejects it with `UnknownLinuxDistro: alpine`. Bookworm-slim adds
# ~30 MB to the builder layer (which is tossed after build anyway —
# only the runtime stage ships) so cost is zero.
FROM node:20-bookworm-slim AS builder

ENV NODE_ENV=production

# Native build deps for bcrypt + curl for the memory-server's mongod
# tarball download.
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 build-essential curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN npm i -g sass

WORKDIR /app

COPY ./package.json ./package.json
COPY ./package-lock.json ./package-lock.json
COPY ./yarn.lock ./yarn.lock
COPY ./next-i18next.config.js ./next-i18next.config.js
COPY ./next-sitemap.config.cjs ./next-sitemap.config.cjs
COPY ./nodemon.json ./nodemon.json
COPY ./vitest.config.ts ./vitest.config.ts
COPY ./vitest.setup.ts ./vitest.setup.ts
COPY ./tools ./tools
COPY ./ui ./ui
COPY ./services ./services
COPY ./shared ./shared

# npm install — matches the validated `.github/workflows/e2e.yml` path
# (`npm install --legacy-peer-deps --no-audit --no-fund`). The repo
# carries both `yarn.lock` and `package-lock.json` but npm + the legacy-
# peer-deps flag is the validated path: yarn 1.x trips on the antd v5↔v6
# peer-dep chain (`@ant-design/compatible` pins to antd v5; we're on v6)
# and silently skips dependent packages like `@anthropic-ai/sdk`,
# producing a build that fails TypeScript module resolution while
# claiming success on the install step.
#
# `NODE_ENV=development` is set ONLY for the install step so devDeps
# (`mongodb-memory-server`, `tsx`) used by the prebuild script land
# in node_modules. Image-level `NODE_ENV=production` would skip them
# and break the prebuild's ephemeral mongo+graphql boot.
#
# `--ignore-scripts` is intentionally NOT passed (vs the e2e CI install)
# because the production runtime needs bcrypt's native binding compiled.
# `python3 build-essential` were added above for that compile step.
RUN --mount=type=cache,target=/root/.npm \
    NODE_ENV=development npm install --legacy-peer-deps --no-audit --no-fund --prefer-offline

# Stamp the running container with its source commit SHA so health
# probes / smoke checks can verify the deploy targets the right commit.
# `GIT_SHA` is passed by CI (`docker build --build-arg
# GIT_SHA="$(git rev-parse HEAD)"`); falls back to `unknown` for local
# image builds.
ARG GIT_SHA=unknown
RUN echo "$GIT_SHA" > /app/.git-sha

# Run the prebuild — boots ephemeral mongo + standalone-graphql, runs
# `next build --webpack`, tears them down. Output is `.next/` + the
# Next 16 standalone runtime artefacts that `next start` reads.
RUN node tools/docker-prebuild.js

# Slim down BEFORE the runtime COPY so the deletions actually shrink
# layer size. Earlier iterations ran `npm prune` + `rm` in the runtime
# stage, but layer ordering means the deleted files still occupy space
# in the underlying COPY layer. Doing it here means the runtime COPY
# brings only the trimmed tree.
#
# Drops: devDeps (mongodb-memory-server, vitest, tsx, ts toolchain,
# the entire `@types/*` corpus, eslint, etc.), `.next/cache` (build-
# time only), and source maps.
RUN npm prune --omit=dev --legacy-peer-deps \
    && rm -rf /app/ui/client/.next/cache \
    && find /app/ui/client/.next -name "*.map" -delete \
    && rm -rf /app/tests /app/tools/legacy /app/__mocks__ /app/scripts \
              /app/.next /app/node_modules/.cache \
    && du -sh /app/node_modules /app/ui/client/.next /app/services /app/shared 2>&1

# ---------------------------------------------------------------- runtime
#
# Standalone runtime — Next.js's `output: 'standalone'` traces the
# server's import graph at build time and emits a self-contained
# `.next/standalone/` folder with:
#   - `server.js` — the Node entry point (replaces `next start`)
#   - minimal `node_modules/` — only packages actually reachable from
#     server-side code (drops the 1 GB+ of devDeps + UI-only deps + the
#     Next CLI itself)
#   - mirrored source tree (so dynamic require()s with relative paths
#     still resolve)
#
# What the runtime image needs:
#   - `.next/standalone/` (entire)           → /app
#   - `.next/static/`                        → /app/ui/client/.next/static
#   - `public/`                              → /app/ui/client/public
#   - `.git-sha`                             → /app/.git-sha (health endpoint)
#
# CMD changes from `npm run start` → `node ui/client/server.js`. The
# legacy compose stack still pins its own `command: npm run start-docker`
# in compose.yaml, so the image's default CMD doesn't affect it.
FROM node:20-bookworm-slim AS runtime

ENV NODE_ENV=production
# `next start` (and standalone server.js) honour `PORT`; default 80
# matches the legacy compose's expectation.
ENV PORT=80
ENV HOSTNAME=0.0.0.0

# Match builder's libc (glibc) — alpine runtime fails on native
# bindings compiled in the builder against bookworm's glibc:
#   "No native build was found for platform=linux runtime=node libc=musl"
# Affects bcrypt, @node-rs/xxhash, etc. Easier to align libc than to
# rebuild native packages for alpine.
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Runtime-generated secrets (first-boot admin password). Permissions
# are tightened at write-time in initialPassword.ts; the dir is created
# here so the node user can write without elevating.
RUN mkdir -p /app/var && chmod 700 /app/var

# Standalone output — the Next build's tree-shaken minimal app.
COPY --from=builder /app/ui/client/.next/standalone /app
# .next/static lives next to the standalone server, NOT inside its
# tree — Next docs explicitly call this out.
COPY --from=builder /app/ui/client/.next/static /app/ui/client/.next/static
# Static assets (favicon, locales, robots, sitemap.xml proxies, etc.).
COPY --from=builder /app/ui/client/public /app/ui/client/public
# Theme JSON presets — `ThemeService.ts` does dynamic `readFileSync` for
# each preset slug, which standalone's import-tracer can't follow.
# Standalone changes cwd to the server.js dir (/app/ui/client/), so
# put themes alongside.
COPY --from=builder /app/ui/client/themes /app/ui/client/themes
# GraphQL schema — `pages/api/graphql.ts` reads it via cwd-relative
# `services/api/schema.graphql`. Standalone tracer doesn't follow the
# `readFileSync` of a non-JS asset, so copy it to the path the runtime
# expects (cwd-relative, with cwd = /app/ui/client/ in standalone).
COPY --from=builder /app/services/api/schema.graphql /app/ui/client/services/api/schema.graphql
# Health endpoint reads /app/.git-sha to surface the running commit.
COPY --from=builder /app/.git-sha /app/.git-sha

EXPOSE 80

# server.js path inside the standalone output mirrors the source layout:
# build was `next build ui/client`, so server.js lands at
# `<standalone>/ui/client/server.js`.
CMD ["node", "ui/client/server.js"]
