FROM node:20-alpine

# Use production node environment by default.
ENV NODE_ENV production

RUN apk add python3 py3-pip make g++ curl

RUN npm i -g sass

WORKDIR /app
# Yarn cache ensurance

# Runtime-generated secrets (first-boot admin password). Tight perms set at
# write-time in initialPassword.ts; directory created up-front so the node
# user can write without root.
RUN mkdir -p /app/var && chown node:node /app/var && chmod 700 /app/var

# Copy the rest of the source files into the image.
COPY ./yarn.lock ./yarn.lock
COPY ./package.json ./package.json
COPY ./next-i18next.config.js ./next-i18next.config.js
COPY ./next-sitemap.config.cjs ./next-sitemap.config.cjs
COPY ./nodemon.json ./nodemon.json
COPY ./tools ./tools
COPY ./infra/certificates ./infra/certificates
COPY ./services ./services
COPY ./shared ./shared
# Run the application as a non-root user.
#USER node

RUN --mount=type=cache,target=/root/.yarn YARN_CACHE_FOLDER=/root/.yarn yarn --frozen-lockfile

# RUN yarn --frozen-lockfile

USER node
