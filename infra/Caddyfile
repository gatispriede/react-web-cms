# --- P3: production domain + automatic HTTPS ---
# `{$DOMAIN}` is sourced from `.env` (see compose.yaml — defaults to `:80`
# when unset, so dev / un-DNSed boxes still serve plain HTTP). When set
# to a real hostname (e.g. `example.com`), Caddy:
#   * obtains + renews a Let's Encrypt cert automatically
#   * redirects HTTP → HTTPS
#   * serves HTTP/3 (UDP/443 is published in compose.yaml)
# Cert state lives in the `caddy_data` named volume so reissues survive
# `docker compose down`. See `docs/runbooks/digitalocean-domain.md` for
# DNS + firewall setup.
#
# `{$SITE_DOMAIN_WWW:www.localhost}` — separate vhost that 301s to the
# canonical apex. We default to a harmless `www.localhost` so dev boots
# don't try to obtain a cert for an apex+www pair the operator hasn't
# declared yet. In prod, set `SITE_DOMAIN_WWW=www.example.com` in `.env`.
{$SITE_DOMAIN_WWW:www.localhost} {
    redir https://{$DOMAIN}{uri} 301
}

{$DOMAIN} {
    encode zstd gzip

    # --- Static uploads served by Caddy, bypassing Next.js ---
    # Uploaded files aren't in Next's build-time public manifest (they live
    # on the host's ./uploads bind mount). Previously the /api/[name].ts
    # and /api/media/[...path].ts handlers served them via synchronous
    # fs.readFileSync, which blocked the Node event loop on every request
    # and competed with GraphQL / SSR for the single vCPU on small droplets.
    # file_server streams from disk, auto-sets ETag + mime, and requires
    # zero app CPU.

    # Admin uploads land in /opt/cms/uploads/images/ (bind-mounted at
    # /srv/uploads/images). Per-site theme/design bundles land in
    # /srv/uploads/bundles (generic replacement for the old `design-v2`
    # namespace — matcher keeps /design-v2/* as a back-compat alias so
    # live content on funisimo.pro/skyclimber.pro keeps resolving while
    # we migrate bundle references).
    @uploads path /bundles/* /design-v2/* /images/*
    handle @uploads {
        root * /srv/uploads
        file_server
        # 5 min freshness + a week of stale-while-revalidate. Caddy also
        # emits ETag, so 304s are cheap even during the stale window.
        # Admins see replaced images within 5 minutes without cache busting.
        header Cache-Control "public, max-age=300, stale-while-revalidate=604800"
    }

    # Legacy path: the /api/[name].ts handler previously served image files
    # as /api/<filename>.<ext>. Catch only requests that look like an image
    # filename (keeps /api/graphql, /api/presence, /api/upload, etc. going
    # to the Next app) and serve them from /srv/uploads/images/.
    @legacyApiImages path_regexp legacy ^/api/([^/]+\.(?i:jpe?g|png|webp|gif|svg|avif))$
    handle @legacyApiImages {
        rewrite * /images/{re.legacy.1}
        root * /srv/uploads
        file_server
        header Cache-Control "public, max-age=300, stale-while-revalidate=604800"
    }

    # --- Everything else → Next.js app ---
    # `lb_try_duration` makes Caddy hold incoming requests for up to 30 s
    # while retrying the upstream — that bridges the brief gap when the
    # `app` container is being swapped on deploy. Most users never see a
    # hiccup because the retry wins before they notice. The separate
    # `fail_duration 0s` keeps Caddy optimistic — we don't want it to
    # mark the sole backend as permanently bad after a single miss.
    reverse_proxy app:80 {
        lb_try_duration 30s
        lb_try_interval 500ms
        fail_duration 0s
        # Treat 502/503/504 from Next as upstream failures so the
        # maintenance page (below) can take over — otherwise a
        # container that's booted but not yet serving would return
        # raw gateway errors to the browser.
        @bad status 502 503 504
        handle_response @bad {
            error 502
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    @static path /_next/static/*
    header @static Cache-Control "public, max-age=31536000, immutable"

    # --- C9: production SWR cache for public pages + anon GraphQL ---
    # Guarded by `PROD_CACHE`. The Node app stamps `X-Cms-Cache-Tag:
    # <bootId>;<feature>=<ver>,…` on every cacheable response; Caddy's
    # built-in HTTP cache module keys entries on URL + that header,
    # so a process restart (new bootId) or an admin write (bumped
    # feature version) evicts naturally without an explicit purge.
    #
    # Caddy's cache module isn't bundled in the standard build — the
    # production deploy uses `caddy-l4 + caddy-cache-handler` (xcaddy)
    # to add it; if you're on stock Caddy the SWR layer is a no-op
    # and responses just go through with the headers attached.
    # Origin sets `Cache-Control: public, max-age=…, stale-while-revalidate=…`
    # so even unsupported intermediate caches do the right thing for
    # straight `max-age` reads.
    #
    # See `docs/runbooks/caddy-cache.md` for the runbook (force-bypass,
    # debugging cache misses, header inspection).

    # --- Maintenance page for deploy windows > retry duration ---
    # If `app` is still unreachable after the 30 s retry budget, Caddy
    # falls here instead of surfacing a raw 502 from the browser's
    # point of view. The static page has a `<meta http-equiv=refresh>`
    # so visitors who land on it get bounced back to the real site as
    # soon as the new container answers. Served from a read-only
    # bind-mount (see compose.yaml).
    handle_errors {
        @downtime expression {http.error.status_code} in [502, 503, 504]
        handle @downtime {
            root * /srv/maintenance
            rewrite * /index.html
            file_server
            header Cache-Control "no-store"
            header Retry-After "30"
        }
    }
}
