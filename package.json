{
  "name": "redis-node-js-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "esnext",
  "scripts": {
    "predev": "npm run dev:db",
    "dev": "next dev --turbo -p 80 ui/client",
    "dev:db": "docker compose -f infra/compose.dev.yaml up -d",
    "dev:db:stop": "docker compose -f infra/compose.dev.yaml down",
    "dev:db:logs": "docker compose -f infra/compose.dev.yaml logs -f mongodb",
    "start": "cross-env NODE_ENV=production next start -p 80 ui/client",
    "start-docker": "cross-env NODE_ENV=production NODE_SERVER_PORT=true BUILD_PORT=3000 next build ui/client && cross-env NODE_ENV=production NODE_SERVER_PORT=true next start -p 80 ui/client",
    "build": "cross-env NODE_ENV=production next build ui/client",
    "build-docker": "cross-env NODE_ENV=production NODE_SERVER_PORT=true BUILD_PORT=3000 next build ui/client",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "lint": "eslint \"./**/*.{ts,tsx}\" --fix",
    "clean": "rm -rf ui/client/.next",
    "dev-server": "nodemon --config ./nodemon.json",
    "standalone-graphql": "cross-env npx tsx --tsconfig services/tsconfig.custom.json services/index.ts",
    "standalone-graphql-docker": "cross-env NODE_SERVER_PORT=true npx tsx --tsconfig services/tsconfig.custom.json services/index.ts",
    "ssl": "npx tsx --tsconfig services/tsconfig.custom.json services/sslServer.ts",
    "generate-schema": "npx @gqty/cli http://localhost:80/api/graphql --target=services/api/generated/index.ts",
    "setupSecrets": "npx auth@latest secret next",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "gqty": {
    "introspections": {
      "https://localhost/api/graphql": {}
    }
  },
  "dependencies": {
    "@ant-design/compatible": "^5.1.4",
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.1.1",
    "@ant-design/icons-svg": "^4.4.2",
    "@ant-design/nextjs-registry": "^1.0.2",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@apollo/server": "^5.5.0",
    "@as-integrations/next": "^4.1.0",
    "@ckeditor/ckeditor5-react": "^11.1.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@graphql-tools/schema": "^10.0.16",
    "@types/bcrypt": "^6.0.0",
    "@types/formidable": "^3.4.5",
    "@types/glidejs__glide": "^3.6.6",
    "@types/lodash.get": "^4.4.9",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.8",
    "@unly/universal-language-detector": "^2.0.3",
    "@vercel/blob": "^2.3.3",
    "antd": "^6.3.6",
    "bcrypt": "^6.0.0",
    "ckeditor5": "^48.0.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "express": "^5.2.1",
    "express-http-proxy": "^2.1.1",
    "formidable": "v3",
    "gqty": "^3.2.2",
    "graphql": "^16.10.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-http": "^1.22.4",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.0.4",
    "i18next-chained-backend": "^5.0.3",
    "i18next-http-backend": "^3.0.2",
    "i18next-xhr-backend": "^3.2.2",
    "isomorphic-dompurify": "^3.9.0",
    "lodash": "^4.17.21",
    "lucide-react": "^1.11.0",
    "mongodb": "^7.2.0",
    "net": "^1.0.2",
    "next": "^16.2.4",
    "next-auth": "^4.24.11",
    "next-cookies": "^2.0.3",
    "next-i18next": "^16.0.5",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.4",
    "next-transpile-modules": "^10.0.1",
    "nodemailer": "^8.0.6",
    "rc-util": "^5.44.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.4",
    "react-icons": "^5.4.0",
    "redis": "^5.12.1",
    "sass": "^1.85.1",
    "sharp": "^0.34.0",
    "styled-components": "^6.1.14",
    "tls": "^0.0.1",
    "uppload": "^3.2.1",
    "zod": "^4.3.6"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-restricted-imports": [
        "error",
        {
          "paths": [
            {
              "name": "styled-icons",
              "message": "styled-icons was dropped — pick a lucide-react equivalent. See roadmap/icon-consolidation.md."
            },
            {
              "name": "@ant-design/icons",
              "message": "Direct imports from @ant-design/icons are forbidden — import the same name from ui/client/lib/icons (lucide adapter). See docs/roadmap/icon-consolidation.md."
            }
          ],
          "patterns": [
            {
              "group": [
                "styled-icons/*",
                "@styled-icons/*"
              ],
              "message": "styled-icons was dropped — pick a lucide-react equivalent. See roadmap/icon-consolidation.md."
            },
            {
              "group": [
                "@ant-design/icons/*"
              ],
              "message": "Direct imports from @ant-design/icons are forbidden — import the same name from ui/client/lib/icons (lucide adapter). See docs/roadmap/icon-consolidation.md."
            }
          ]
        }
      ]
    }
  },
  "browser": {
    "crypto": false,
    "stream": false
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "immutable": "^5.0.3",
    "jsdom": "^29.0.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
