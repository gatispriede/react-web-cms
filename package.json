{
  "name": "redis-node-js-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "esnext",
  "scripts": {
    "dev": "next dev --turbo -p 80 src/frontend  ",
    "start": "cross-env NODE_ENV=production next start -p 80 src/frontend ",
    "start-docker": "cross-env NODE_ENV=production  NODE_SERVER_PORT=true next start -p 80 src/frontend ",
    "build": "cross-env NODE_ENV=production next build src/frontend",
    "build-docker": "cross-env NODE_ENV=production NODE_SERVER_PORT=true BUILD_PORT=3000 next build src/frontend",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "lint": "eslint \"./**/*.{ts,tsx}\" --fix",
    "clean": "rm -rf src/frontend/.next",
    "dev-server": "nodemon --config ./nodemon.json",
    "standalone-graphql": "cross-env npx tsx --tsconfig src/Server/tsconfig.custom.json src/Server/index.ts",
    "standalone-graphql-docker": "cross-env NODE_SERVER_PORT=true npx tsx --tsconfig src/Server/tsconfig.custom.json src/Server/index.ts",
    "ssl": "npx tsx --tsconfig src/Server/tsconfig.custom.json src/Server/sslServer.ts",
    "generate-schema": "npx @gqty/cli http://localhost:80/api/graphql --target=src/frontend/gqty/index.ts ",
    "setupSecrets": "npx auth@latest secret next",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "gqty": {
    "introspections": {
      "https://localhost/api/graphql": {}
    }
  },
  "dependencies": {
    "@ant-design/compatible": "^5.1.4",
    "@ant-design/cssinjs": "^1.23.0",
    "@ant-design/icons": "^5.6.0",
    "@ant-design/icons-svg": "^4.4.2",
    "@ant-design/nextjs-registry": "^1.0.2",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@ckeditor/ckeditor5-react": "^9.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@graphql-tools/schema": "^10.0.16",
    "@types/bcrypt": "^5.0.2",
    "@types/formidable": "^3.4.5",
    "@types/glidejs__glide": "^3.6.6",
    "@types/lodash.get": "^4.4.9",
    "@types/micro-cors": "^0.1.5",
    "@types/node": "^22.12.0",
    "@types/react": "^19.0.8",
    "@unly/universal-language-detector": "^2.0.3",
    "@vercel/blob": "^0.27.1",
    "antd": "^5.24.3",
    "apollo-server": "^3.13.0",
    "apollo-server-micro": "^3.13.0",
    "bcrypt": "^5.1.1",
    "ckeditor5": "^45.0.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "express": "^4.21.2",
    "express-http-proxy": "^2.1.1",
    "formidable": "v3",
    "gqty": "^3.2.2",
    "graphql": "^16.10.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-http": "^1.22.4",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.4",
    "i18next-chained-backend": "^4.6.2",
    "i18next-http-backend": "^3.0.2",
    "i18next-xhr-backend": "^3.2.2",
    "isomorphic-dompurify": "^3.9.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.469.0",
    "micro": "^9.4.1",
    "micro-cors": "^0.1.1",
    "mongodb": "^6.12.0",
    "net": "^1.0.2",
    "next": "^15.1.6",
    "next-auth": "^4.24.11",
    "next-cookies": "^2.0.3",
    "next-i18next": "^15.4.2",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.4",
    "next-transpile-modules": "^10.0.1",
    "node-sass": "^9.0.0",
    "rc-util": "^5.44.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-icons": "^5.4.0",
    "redis": "^4.7.0",
    "sass": "^1.85.1",
    "styled-components": "^6.1.14",
    "tls": "^0.0.1",
    "uppload": "^3.2.1",
    "zod": "^4.3.6"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-restricted-imports": [
        "error",
        {
          "paths": [
            {
              "name": "styled-icons",
              "message": "styled-icons was dropped — pick a lucide-react equivalent. See roadmap/icon-consolidation.md."
            },
            {
              "name": "@ant-design/icons",
              "message": "Direct imports from @ant-design/icons are forbidden — import the same name from src/frontend/components/common/icons (lucide adapter). See roadmap/icon-consolidation.md."
            }
          ],
          "patterns": [
            {
              "group": [
                "styled-icons/*",
                "@styled-icons/*"
              ],
              "message": "styled-icons was dropped — pick a lucide-react equivalent. See roadmap/icon-consolidation.md."
            },
            {
              "group": [
                "@ant-design/icons/*"
              ],
              "message": "Direct imports from @ant-design/icons are forbidden — import the same name from src/frontend/components/common/icons (lucide adapter). See roadmap/icon-consolidation.md."
            }
          ]
        }
      ]
    }
  },
  "browser": {
    "crypto": false,
    "stream": false
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "immutable": "^5.0.3",
    "jsdom": "^29.0.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
