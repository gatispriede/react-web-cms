{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "types": ["vitest/globals"],
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@services/*": ["./*"],
      "@client/*": ["../ui/client/*"],
      "@admin/*": ["../ui/admin/*"],
      "@shared/*": ["../shared/*"],
      "@interfaces/*": ["../shared/types/*"],
      "@enums/*": ["../shared/enums/*"],
      "@utils/*": ["../shared/utils/*"]
    },
    "baseUrl": "."
  },
  "exclude": [
    "node_modules"
  ],
}
